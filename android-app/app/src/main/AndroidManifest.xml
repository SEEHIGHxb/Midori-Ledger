<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.midori.ledger">

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Backup is off on purpose. The WebView's localStorage holds the whole
        ledger plus preferences.syncKey, the symmetric key that decrypts every
        ZenSync blob. Android's Auto Backup would copy that data directory to
        the user's Google Drive, moving a finance app's plaintext records and
        its encryption key onto a third-party service the user never opted
        into for this purpose. dataExtractionRules covers API 31+, where cloud
        backup and device-to-device transfer are governed separately.
        Migration is meant to go through the app's own export/import or sync.
    -->
    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Midori"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar">
        
        <!--
            launchMode=singleTask so the Google-sign-in deep link is delivered
            to the running activity (onNewIntent), reusing the WebView that holds
            the ledger, instead of spawning a second copy with empty state.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Auth return channel. The sign-in Custom Tab finishes on the
                auth-callback.html bridge page, which redirects to
                com.midori.ledger://auth#<tokens>; this filter routes that back
                into the app. The scheme is app-private, so Supabase never needs
                it in its Redirect URLs — only the https bridge page.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.midori.ledger" android:host="auth" />
            </intent-filter>
        </activity>
    </application>

</manifest>
